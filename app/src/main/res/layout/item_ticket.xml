<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left color bar -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#6B7599" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Row 1: Ticket ID + Status Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tvTicketId"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="#TKT-0042"
                    android:textSize="12sp"
                    android:textColor="#7A8091"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OPEN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#3B6FE8"
                    android:background="@drawable/bg_status_badge"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

            </LinearLayout>

            <!-- Row 2: Subject Title -->
            <TextView
                android:id="@+id/tvSubject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Library Access Portal Error"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A2340"
                android:layout_marginBottom="5dp"/>

            <!-- Row 3: Category Tag -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IT Support"
                android:textSize="12sp"
                android:textColor="#1A2340"
                android:background="@drawable/bg_category_tag"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="10dp"/>

            <!-- Row 4: Assigned Faculty + Date/Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Faculty Avatar -->
                <ImageView
                    android:id="@+id/ivFacultyAvatar"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_avatar_gray"
                    android:padding="5dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile_user"/>

                <!-- Faculty Name -->
                <TextView
                    android:id="@+id/tvAssignedName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Not Assigned"
                    android:textSize="12sp"
                    android:textColor="#7A8091"
                    android:fontFamily="sans-serif"/>

                <!-- Date & Time -->
                <TextView
                    android:id="@+id/tvDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 Mar 2026  10:30 AM"
                    android:textSize="11sp"
                    android:textColor="#9CA3AF"
                    android:fontFamily="sans-serif"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
