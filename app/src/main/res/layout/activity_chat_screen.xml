<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#EEF0F3"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0F2F5"
        android:orientation="vertical">

        <!-- CHAT TOP BAR — Navy -->
        <LinearLayout
            android:id="@+id/userdetailcontainer"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="#1A2340"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <!-- Back arrow -->
            <ImageView
                android:id="@+id/btnChatBack"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_back"
                app:tint="#FFFFFF" />

            <!-- Avatar with green dot -->
            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginEnd="12dp">

                <ImageView
                    android:id="@+id/chatHeaderAvatar"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_avatar_dark"
                    android:padding="8dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_profile_user"
                     />

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/dot_green" />
            </FrameLayout>

            <!-- Name + designation -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvChatName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/playfairdisplay_bold"
                    android:text="Dr. Sarah Jenkins"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvChatDept"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dmsans_regular"
                    android:letterSpacing="0.08"
                    android:text="REGISTRAR OFFICE"
                    android:textColor="#AAAACC"
                    android:textSize="11sp" />
            </LinearLayout>


        </LinearLayout>

        <!-- MESSAGES AREA -->
        <ScrollView
            android:id="@+id/svMessages"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F0F2F5"
            android:clipToPadding="false"
            android:paddingHorizontal="14dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:id="@+id/llMessages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            </LinearLayout>
        </ScrollView>

        <!-- MESSAGE INPUT BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <!-- Attachment icon -->
            <ImageView
                android:id="@+id/addAttachment"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_attachment"
                app:tint="#AAAAAA" />

            <!-- Type box -->
            <EditText
                android:id="@+id/etChatMessage"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_ticket"
                android:fontFamily="@font/dmsans_regular"
                android:hint="Type your message..."
                android:inputType="text"
                android:maxLines="1"
                android:paddingHorizontal="14dp"
                android:textColor="#1A2340"
                android:textColorHint="#CCCCCC"
                android:textSize="14sp" />

            <!-- Send button — Gold circle -->
            <FrameLayout
                android:id="@+id/btnSend"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_send_btn"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_send"
                    app:tint="#1A2340" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>
    <!-- END PAGE 1 -->-->

</LinearLayout>