<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="2dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#EAE7E1"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvAnnouncementCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="ACADEMIC"
            android:textColor="#3B6FE8"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAnnouncementTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/dmsans_bold"
            android:text="End of Semester Exam Schedule Released"
            android:textColor="#1A2340"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvAnnouncementMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Posted Oct 23, 2023"
            android:textColor="#9AA1B2"
            android:textSize="11sp" />
    </LinearLayout>

</androidx.cardview.widget.CardView>
