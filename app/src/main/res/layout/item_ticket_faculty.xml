<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_stat_white"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="horizontal">

    <!-- Color left bar -->
    <View
        android:id="@+id/leftBar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="14dp"
        android:background="#E53935" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingVertical="14dp"
        android:paddingEnd="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvIdSubject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/dmsans_regular"
                android:text="#1024 · Login Issue"
                android:textColor="#888880"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_status_not_opened_badge"
                android:fontFamily="@font/dmsans_semibold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="NOT OPENED"
                android:textColor="#3F51B5"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvPriorityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_priority_high_badge"
                android:fontFamily="@font/dmsans_semibold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="HIGH PRIORITY"
                android:textColor="#E53935"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:fontFamily="@font/dmsans_semibold"
            android:text="Ticket Subject"
            android:textColor="#1A2340"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dmsans_regular"
            android:text="Category · Time"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>