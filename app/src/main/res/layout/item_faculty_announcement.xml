<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_stat_white"
    android:orientation="horizontal">

    <View
        android:id="@+id/viewPriorityStrip"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:background="#1A2340" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvAnnouncementCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_navy_outline"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="ACADEMIC"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAnnouncementDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="end"
                android:text="27 Apr 2026, 11:00 AM"
                android:textColor="#888880"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAnnouncementTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/playfairdisplay_bold"
            android:text="Mid-sem timetable revised"
            android:textColor="#1A2340"
            android:textSize="19sp" />

        <TextView
            android:id="@+id/tvAnnouncementBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/dmsans_regular"
            android:lineSpacingExtra="2dp"
            android:text="Updated notice body goes here."
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAnnouncementMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/dmsans_regular"
            android:text="Faculty Office  •  All Campus  •  Important"
            android:textColor="#888880"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
