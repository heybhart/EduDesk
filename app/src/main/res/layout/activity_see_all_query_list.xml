<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F0F2F5"
    android:orientation="vertical">

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#F0F2F5"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <!-- Ticket icon box -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_stat_navy">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_ticket"
                app:tint="#FFFFFF" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/playfairdisplay_bold"
            android:text="All Tickets"
            android:textColor="#1A2340"
            android:textSize="22sp" />

        <!-- Filter icon -->
        <ImageView
            android:id="@+id/btnFilter"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_filter"
            app:tint="#1A2340" />

        <!-- Bell with red dot -->
        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notification"
                app:tint="#1A2340" />
            <!-- Red notification dot -->
            <View
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="1dp"
                android:background="@drawable/dot_red" />
        </FrameLayout>
    </LinearLayout>

    <!-- ===== SEARCH BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/baseline_search_24"
            app:tint="#AAAAAA" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@null"
            android:fontFamily="@font/dmsans_regular"
            android:hint="Search ticket ID, student, or staff..."
            android:inputType="text"
            android:maxLines="1"
            android:textColor="#333333"
            android:textColorHint="#BBBBBB"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- ===== FILTER TABS — Horizontal scroll ===== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ALL — selected navy pill -->
            <TextView
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_selected"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/dmsans_semibold"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="All"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <!-- Assigned / Open -->
            <TextView
                android:id="@+id/tabOpen"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_normal"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/dmsans_regular"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="My Tickets"
                android:textColor="#555555"
                android:textSize="13sp" />

            <!-- Resolved -->
            <TextView
                android:id="@+id/tabResolved"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_tab_normal"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/dmsans_regular"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="Resolved"
                android:textColor="#555555"
                android:textSize="13sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ===== TICKET LIST ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F0F2F5"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:id="@+id/ticketListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">
            <!-- Dynamic tickets will be added here -->
        </LinearLayout>
    </ScrollView>

</LinearLayout>