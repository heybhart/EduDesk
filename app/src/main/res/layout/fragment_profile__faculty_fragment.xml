<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDE8DC"
    android:orientation="vertical">

    <!-- ===== NAVY TOP BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#1A2340"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_back"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/playfairdisplay_bold"
            android:gravity="center"
            android:text="Faculty Profile"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="&#8942;"
            android:textColor="#FFFFFF"
            android:textSize="22sp" />
    </LinearLayout>

    <!-- ===== SCROLLABLE BODY ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#EDE8DC"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="30dp">

            <!-- ===== AVATAR SECTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="20dp">

                <!-- Gold ring + avatar + verified badge -->
                <FrameLayout
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_marginBottom="18dp">

                    <!-- Gold outer ring -->
                    <FrameLayout
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:background="@drawable/bg_avatar_gold_ring">

                        <!-- White spacing ring -->
                        <FrameLayout
                            android:layout_width="118dp"
                            android:layout_height="118dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_avatar_white_ring">

                            <!-- Avatar image -->
                            <ImageView
                                android:id="@+id/ivFacultyAvatar"
                                android:layout_width="112dp"
                                android:layout_height="112dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_avatar_teal"
                                android:padding="20dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_profile_user"
                                android:tint="#FFFFFF" />
                        </FrameLayout>
                    </FrameLayout>

                    <!-- Gold verified badge — bottom right -->
                    <FrameLayout
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:background="@drawable/bg_verified_badge">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:fontFamily="@font/dmsans_semibold"
                            android:text="&#10003;"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                    </FrameLayout>
                </FrameLayout>

                <!-- Name -->
                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:fontFamily="@font/playfairdisplay_bold"
                    android:text="Dr. Sarah Jenkins"
                    android:textColor="#1A2340"
                    android:textSize="26sp" />

                <!-- Role -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:fontFamily="@font/dmsans_regular"
                    android:text="Senior Registrar / Professor"
                    android:textColor="#666655"
                    android:textSize="14sp" />

                <!-- PRN pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_prn_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginEnd="7dp"
                        android:src="@drawable/ic_lock"
                        android:tint="#555544" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dmsans_regular"
                        android:text="PRN: FAC-2023-0881"
                        android:textColor="#444433"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== EMPLOYMENT DETAILS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/playfairdisplay_bold"
                android:text="Employment Details"
                android:textColor="#1A2340"
                android:textSize="20sp" />

            <!-- White card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="22dp"
                android:background="@drawable/bg_detail_card"
                android:orientation="vertical">

                <!-- DEPARTMENT row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp">

                    <!-- Icon box -->
                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_icon_box">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_department"
                            android:tint="#1A2340" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="@font/dmsans_semibold"
                            android:letterSpacing="0.08"
                            android:text="DEPARTMENT"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvProfileDepartment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dmsans_regular"
                            android:text="Office of the Registrar"
                            android:textColor="#1A2340"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="18dp"
                    android:background="#F0EDE5" />

                <!-- DESIGNATION row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_icon_box">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_briefcase"
                            android:tint="#1A2340" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="@font/dmsans_semibold"
                            android:letterSpacing="0.08"
                            android:text="DESIGNATION"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dmsans_regular"
                            android:text="Senior Admin &amp; Faculty"
                            android:textColor="#1A2340"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="18dp"
                    android:background="#F0EDE5" />

                <!-- COLLEGE EMAIL row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_icon_box">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_email1"
                            android:tint="#1A2340" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="@font/dmsans_semibold"
                            android:letterSpacing="0.08"
                            android:text="COLLEGE EMAIL"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dmsans_regular"
                            android:text="sarah.j@university.edu"
                            android:textColor="#1A2340"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- Copy icon -->
                    <ImageView
                        android:id="@+id/btnCopyEmail"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:src="@drawable/ic_copy"
                        android:tint="#AAAAAA" />
                </LinearLayout>

            </LinearLayout>

            <!-- ===== PERSONAL DETAILS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/playfairdisplay_bold"
                android:text="Personal Details"
                android:textColor="#1A2340"
                android:textSize="20sp" />

            <!-- White card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="26dp"
                android:background="@drawable/bg_detail_card"
                android:orientation="vertical">

                <!-- GENDER row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_icon_box">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_profile_user"
                            android:tint="#1A2340" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="@font/dmsans_semibold"
                            android:letterSpacing="0.08"
                            android:text="GENDER"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvProfileGender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dmsans_regular"
                            android:text="Female"
                            android:textColor="#1A2340"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="18dp"
                    android:background="#F0EDE5" />

                <!-- STAFF ID row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="18dp"
                    android:paddingVertical="16dp">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_icon_box">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_id_card"
                            android:tint="#1A2340" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:fontFamily="@font/dmsans_semibold"
                            android:letterSpacing="0.08"
                            android:text="STAFF ID"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dmsans_regular"
                            android:text="FAC-2023-0881"
                            android:textColor="#1A2340"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== SIGN OUT BUTTON — Gold border ===== -->
            <LinearLayout
                android:id="@+id/btnSignOut"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_signout_gold"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_signout_arrow"
                    android:tint="#C9A84C" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dmsans_semibold"
                    android:text="Sign Out"
                    android:textColor="#C9A84C"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Last login -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dmsans_regular"
                android:gravity="center"
                android:text="Last login: Today at 08:45 AM"
                android:textColor="#AAAAAA"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>