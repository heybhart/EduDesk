<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Checked = Navy background, gold border -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#1A2340"/>
            <corners android:radius="8dp"/>
            <stroke android:width="2dp" android:color="#C9A84C"/>
        </shape>
    </item>

    <!-- Pressed state = Gold border preview -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#F5F0E8"/>
            <corners android:radius="8dp"/>
            <stroke android:width="2dp" android:color="#C9A84C"/>
        </shape>
    </item>

    <!-- Default = White with light border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <corners android:radius="8dp"/>
            <stroke android:width="1.5dp" android:color="#E0E0E0"/>
        </shape>
    </item>

</selector>
